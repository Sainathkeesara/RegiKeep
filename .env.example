# ─── Server ───────────────────────────────────────────────────────────────────
LISTEN_ADDR=:8080
ALLOWED_ORIGINS=*

# ─── Database ────────────────────────────────────────────────────────────────
DB_PATH=/data/regikeep.db

# ─── Daemon ──────────────────────────────────────────────────────────────────
DAEMON_WORKERS=4
DAEMON_AUTO_START=true

# ─── Oracle OCIR ─────────────────────────────────────────────────────────────
OCIR_ENDPOINT=OCI Endpoint
OCIR_TENANCY=
OCIR_USERNAME=
OCIR_AUTH_TOKEN=
OCIR_REGION=
# Compartment OCID — fill in from OCI Console > Identity > Compartments
OCIR_COMPARTMENT_OCID=

# ─── Amazon ECR ──────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
ECR_ACCOUNT_ID=

# ─── Docker Hub ──────────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=
DOCKERHUB_ACCESS_TOKEN=
DOCKERHUB_NAMESPACE=

# ─── Archive — AWS S3 ────────────────────────────────────────────────────────
ARCHIVE_S3_BUCKET=regikeep-archive
ARCHIVE_S3_REGION=
ARCHIVE_S3_PREFIX=/archives

# ─── Archive — Oracle OCI Object Storage ─────────────────────────────────────
ARCHIVE_OCI_BUCKET=regikeep-archive
ARCHIVE_OCI_NAMESPACE=
ARCHIVE_OCI_REGION=

# ─── Trivy Vulnerability Scanning ────────────────────────────────────────────
# To run Trivy: docker run -d -p 4954:4954 aquasec/trivy server --listen 0.0.0.0:4954
TRIVY_SERVER_URL=

# ─── Frontend (passed to Vite at build time) ──────────────────────────────────
# For docker-compose: backend service name resolves to http://backend:8080
# For local dev:      set to http://localhost:8080
# Leave unset to use the Vite proxy (localhost:5173 → localhost:8080)
VITE_SUPABASE_URL=http://localhost:8080
VITE_SUPABASE_ANON_KEY=regikeep-local

# ─── CLI control (used by rgk daemon start/stop/status) ───────────────────────
# URL of the running rgk serve instance. Default: http://localhost:8080
RGK_API_URL=http://localhost:8080
