# Backend URL — all API calls go here.
# For local dev (npm run dev): set to http://localhost:8080
# For Docker / production: use your deployed backend URL
# Leave unset to route through the Vite proxy (dev) or nginx proxy (prod).
VITE_SUPABASE_URL=http://localhost:8080

# Anon key — not currently validated by backend, any non-empty string works
VITE_SUPABASE_ANON_KEY=regikeep-local
