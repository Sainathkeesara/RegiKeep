# Improved .env file
# ─── Server ───────────────────────────────────────────────────────────────────
LISTEN_ADDR=:8080
ALLOWED_ORIGINS=*

# ─── Database ────────────────────────────────────────────────────────────────
DB_PATH=/data/regikeep.db

# ─── Daemon ──────────────────────────────────────────────────────────────────
DAEMON_WORKERS=4
DAEMON_AUTO_START=true

# ─── Oracle OCIR ─────────────────────────────────────────────────────────────
OCIR_ENDPOINT=
OCIR_TENANCY=
OCIR_USERNAME=
OCIR_AUTH_TOKEN=
OCIR_REGION=
# Compartment OCID — fill in from OCI Console > Identity > Compartments
OCIR_COMPARTMENT_OCID=

# ─── Amazon ECR ──────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
ECR_ACCOUNT_ID=

# ─── Docker Hub ──────────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=
DOCKERHUB_ACCESS_TOKEN=
DOCKERHUB_NAMESPACE=

# ─── Archive — AWS S3 ────────────────────────────────────────────────────────
ARCHIVE_S3_BUCKET=
ARCHIVE_S3_REGION=
ARCHIVE_S3_PREFIX=

# ─── Archive — Oracle OCI Object Storage ─────────────────────────────────────
ARCHIVE_OCI_BUCKET=regikeep-archive
ARCHIVE_OCI_NAMESPACE=
ARCHIVE_OCI_REGION=

# ─── Trivy Vulnerability Scanning ────────────────────────────────────────────
# To run Trivy: docker run -d -p 4954:4954 aquasec/trivy server --listen 0.0.0.0:4954
TRIVY_SERVER_URL=
